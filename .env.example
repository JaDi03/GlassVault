# ==========================================
# MOCK MODE (set to "false" for real integrations)
# ==========================================
MOCK_MODE=true
VITE_MOCK_MODE=true

# Venice AI
VENICE_API_KEY=

# 1Shot API - Public Relayer
ONESHOT_RELAYER_URL=https://relayer.1shotapi.com/relayers

# Webhook base URL (your Vercel deployment URL, needed for 1Shot callbacks)
# Example: https://glassvault.vercel.app
WEBHOOK_BASE_URL=

# Networks - verified from 1Shot server wallet configuration
BASE_SEPOLIA_CHAIN_ID=84532
MONAD_TESTNET_CHAIN_ID=10143

# 1Shot server wallet addresses (from your 1Shot dashboard)
# Base Sepolia wallet
ONESHOT_WALLET_BASE_SEPOLIA=0x33....FE41
# Monad Testnet wallet
ONESHOT_WALLET_MONAD=0xDe....0bAC

# MetaMask SDK
VITE_METAMASK_APP_NAME=GlassVault
VITE_METAMASK_APP_URL=https://glassvault.vercel.app

# Backend port (local dev only)
PORT=3001

# x402 Mock API (internal endpoint)
X402_PRICE_API_PATH=/api/data/prices

# ==========================================
# AGENT WALLET CREDENTIALS (Zero Assumptions)
# ==========================================
# This is the independent wallet that the AI Agent uses to execute transactions
# on behalf of the users. IT IS NOT THE USER'S PRIVATE KEY.
# Generate a fresh Private Key for the Agent (e.g. from MetaMask) and put it here.
AGENT_PRIVATE_KEY=0x...

# Standard RPC URL to broadcast the Agent's transactions to Base Sepolia
# (You can use Alchemy, Infura, or public RPCs)
RPC_URL_BASE_SEPOLIA=https://sepolia.base.org
