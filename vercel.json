{
  "buildCommand": "npm run build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/apps/api/$1" }
  ],
  "functions": {
    "apps/api/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  }
}
